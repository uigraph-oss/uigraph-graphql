extend type Query {
    me: Me!
    myOrgs: [OrgSummary!]!
}

extend type Mutation {
    switchOrg(orgId: ID!): Boolean!
}

type Me {
    userId:       ID!
    email:        String!
    name:         String!
    login:        String!
    role:         String!
    authProvider: String!
}

type OrgSummary {
    id:     ID!
    name:   String!
    slug:   String!
    role:   String!
    active: Boolean!
}
